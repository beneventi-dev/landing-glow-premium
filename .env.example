# ============================================
# CONFIGURACIÓN DE CORREO (SMTP)
# ============================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu-correo@gmail.com
SMTP_PASS=tu-app-password-o-contraseña

# ============================================
# DESTINATARIOS (separados por coma)
# ============================================
EMAIL_RECIPIENTS=ventas@glow.cl,ceo@glow.cl,asistente@glow.cl

# ============================================
# REMITENTE
# ============================================
EMAIL_SENDER=no-reply@glow.cl

# ============================================
# MENSAJE DE AGRADECIMIENTO (Personalizado)
# ============================================
THANK_YOU_MESSAGE=Hemos recibido tu solicitud de asesoría. En los próximos 5 minutos, una de nuestras expertas en belleza revisará tu perfil y te enviará un diagnóstico personalizado.

# ============================================
# GOOGLE SHEETS (Opcional - Descomentar si usas)
# ============================================
# GOOGLE_SHEETS_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# GOOGLE_SHEETS_CLIENT_EMAIL=tu-service-account@proyecto.iam.gserviceaccount.com
# GOOGLE_SHEETS_SPREADSHEET_ID=1ABC123_xyz...