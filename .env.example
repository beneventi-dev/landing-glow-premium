# ============================================
# CONFIGURACIÓN DE CORREO (SMTP)
# ============================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu-correo@gmail.com
SMTP_PASS=tu-app-password-o-contraseña

# ============================================
# DESTINATARIOS (separados por coma)
# ============================================
EMAIL_RECIPIENTS=ventas@glow.cl,ceo@glow.cl

# ============================================
# REMITENTE
# ============================================
EMAIL_SENDER=no-reply@glow.cl

# ============================================
# MENSAJE DE AGRADECIMIENTO
# ============================================
THANK_YOU_MESSAGE=Hemos recibido tu solicitud. En los próximos 5 minutos, nuestro equipo te contactará.

# ============================================
# FIREBASE (Realtime Database)
# ============================================
FIREBASE_DATABASE_URL=https://glow-bcf37-default-rtdb.firebaseio.com
FIREBASE_CREDENTIALS={"type":"service_account","project_id":"glow-bcf37","private_key":"..."}
